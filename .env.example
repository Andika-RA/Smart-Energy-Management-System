# Salin file ini menjadi .env lalu sesuaikan nilainya sebelum menjalankan
# `docker compose up` atau `make up`. Tanpa file .env, docker-compose.yml tidak
# bisa membaca variabel-variabel berikut, dan service iot-simulator (yang memuat
# env_file: .env) bisa gagal start karena filenya tidak ditemukan.

# ── Database (MySQL) ─────────────────────────────────────────────
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=

# ── Message Broker ──────────────────────────────────────────────────────
MQTT_BROKER=
MQTT_PORT=
RABBITMQ_HOST=
RABBITMQ_USER=
RABBITMQ_PASS=

# ── Keamanan / Auth ───────────────────────────────────────────────
# Dipakai bersama oleh oauth-server & api-gateway untuk menandatangani
# dan memverifikasi JWT. HARUS SAMA pada kedua service.
JWT_SECRET=

# ── Grafana ───────────────────────────────────────────────────────
GRAFANA_USER=
GRAFANA_PASS=
