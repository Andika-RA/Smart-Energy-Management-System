    {
        "id": "func_power",
        "type": "function",
        "z": "1b72ad3e978b41bf",
        "name": "Enrich Power Data",
        "func": "let d = msg.payload;\nif (!d.id) {\n    d.id = \"WKW-PWR-\" + Date.now();\n    let now = new Date();\n    d.timestamp = now.toISOString();\n    d.hour = now.getHours();\n    let day = now.getDay();\n    d.day_of_week = day === 0 ? 6 : day - 1;\n}\nmsg.payload = d;\nreturn msg;",
        "outputs": 1,
        "x": 350,
        "y": 320,
        "wires": [
            [
                "http_power"
            ]
        ]
