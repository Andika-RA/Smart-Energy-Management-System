    {
        "id": "func_sensor_prep",
        "type": "function",
        "z": "1b72ad3e978b41bf",
        "name": "Prep Sensor & Req Token",
        "func": "let d = msg.payload;\nif (!d.id) {\n    d.id = \"WKW-SNS-\" + Date.now();\n    let now = new Date();\n    d.timestamp = now.toISOString();\n    d.timestamp_hour = now.getHours();\n}\nmsg.sensor_data = d;\nmsg.payload = {\n    \"grant_type\": \"client_credentials\",\n    \"client_id\": \"iot_gateway\",\n    \"client_secret\": \"password\"\n};\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\nreturn msg;",
