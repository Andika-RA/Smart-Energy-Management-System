    {
        "id": "mqtt_grid_wokwi",
        "type": "mqtt in",
        "z": "1b72ad3e978b41bf",
        "name": "Wokwi: Grid",
        "topic": "city/+/grid",
        "qos": "0",
        "datatype": "json",
        "broker": "broker_hivemq",
        "inputs": 0,
        "x": 100,
        "y": 100,
        "wires": [
            [
                "func_grid_prep"
            ]
        ]
    },
    {
        "id": "func_grid_prep",
        "type": "function",
        "z": "1b72ad3e978b41bf",
        "name": "Prep Grid & Req Token",
        "func": "let d = msg.payload;\n// Petakan field Wokwi ke field yang dibutuhkan PHP API\n// Wokwi kirim: { zone: 'zone1', voltage, current, power_factor }\n// API butuh:   { zone_id: 1, voltage, current, power_factor }\nlet zone_id = 1;\nif (d.zone) {\n    zone_id = parseInt(d.zone.replace(/[^0-9]/g, '')) || 1;\n}\nmsg.sensor_data = {\n    zone_id: zone_id,\n    voltage: d.voltage,\n    current: d.current,\n    power_factor: d.power_factor\n};\n\n// Siapkan payload untuk minta token M2M\nmsg.payload = {\n    \"grant_type\": \"client_credentials\",\n    \"client_id\": \"iot_gateway\",\n    \"client_secret\": \"password\"\n};\nmsg.headers = {\n    \"Content-Type\": \"application/json\"\n};\nreturn msg;",
        "outputs": 1,
        "x": 300,
        "y": 100,
        "wires": [
            [
                "http_grid_token"
            ]
        ]
    },
    {
        "id": "http_grid_token",
        "type": "http request",
        "z": "1b72ad3e978b41bf",
        "name": "POST /oauth/token",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://api-gateway:3060/oauth/token",
        "x": 520,
        "y": 100,
        "wires": [
            [
                "func_grid_auth"
            ]
        ]
    },
    {
        "id": "func_grid_auth",
        "type": "function",
        "z": "1b72ad3e978b41bf",
        "name": "Set Auth & Restore Data",
        "func": "if (msg.payload && msg.payload.data && msg.payload.data.access_token) {\n    msg.headers = {\n        \"Authorization\": \"Bearer \" + msg.payload.data.access_token,\n        \"Content-Type\": \"application/json\"\n    };\n    // Kembalikan data sensor ke payload utama untuk dikirim\n    msg.payload = msg.sensor_data;\n    return msg;\n} else {\n    node.error(\"Gagal mendapatkan token\", msg);\n    return null;\n}",
        "outputs": 1,
        "x": 750,
        "y": 100,
        "wires": [
            [
                "http_grid_data"
            ]
        ]
    },
    {
        "id": "http_grid_data",
        "type": "http request",
        "z": "1b72ad3e978b41bf",
        "name": "POST /api/grid-readings",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://api-gateway:3060/api/grid-readings",
